# ═══════════════════════════════════════════════
# Environment Variables — Sistem LKM Matematika PGSD
# Target: 300 mahasiswa, PostgreSQL managed, serverless
# ═══════════════════════════════════════════════

# Database — Runtime (pooled connection untuk serverless)
# Neon: tambahkan ?pgbouncer=true atau gunakan pooled endpoint
# Supabase: gunakan connection pooler URL (port 6543)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Database — Direct (untuk migration, tanpa pooler)
# Neon: gunakan direct endpoint
# Supabase: gunakan direct connection (port 5432)
# Jika tidak pakai pooler, bisa sama dengan DATABASE_URL
DIRECT_DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Auth Secret (WAJIB — generate: openssl rand -base64 32)
AUTH_SECRET="ganti-dengan-string-random-minimal-32-karakter"

# App URL (URL publik setelah deploy)
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"

# Node Environment
NODE_ENV="production"
