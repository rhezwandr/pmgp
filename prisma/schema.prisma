generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
}

enum TestType {
  KAM
  PRE_TEST
  POST_TEST
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
}

enum ModuleProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum LKMSubmissionStatus {
  DRAFT
  SUBMITTED
  GRADED
}

enum AutomaticFeedbackSourceType {
  KAM
  PRE_TEST
  LKM
  POST_TEST
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student       Student?
  teacher       Teacher?
  notifications Notification[]
}

model Student {
  id        String   @id @default(cuid())
  userId    String   @unique
  nim       String   @unique
  classId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  class            Class?                  @relation(fields: [classId], references: [id])
  classMemberships ClassMember[]
  testAttempts     StudentTestAttempt[]
  answers          StudentAnswer[]
  moduleProgress   StudentModuleProgress[]
  lkmSubmissions   StudentLKMSubmission[]
  peerAssessments  PeerAssessment[]
  learningFeedback LearningFeedback[]
  automaticFeedback AutomaticFeedback[]
  activityLogs     ActivityLog[]
  teacherNotes     TeacherNote[]
  receivedMessages TeacherMessage[]
  teacherLkmFeedback TeacherLkmFeedback[]

  @@index([classId])
}

model Teacher {
  id             String   @id @default(cuid())
  userId         String   @unique
  lecturerNumber String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  classes      Class[]
  teacherNotes TeacherNote[]
  sentMessages TeacherMessage[]
  teacherLkmFeedback TeacherLkmFeedback[]
}

model Class {
  id           String   @id @default(cuid())
  name         String
  code         String   @unique
  semester     String
  academicYear String
  teacherId    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  teacher Teacher       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  students Student[]
  members  ClassMember[]

  @@index([teacherId])
}

model ClassMember {
  id        String @id @default(cuid())
  classId   String
  studentId String
  createdAt DateTime @default(now())

  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId])
  @@index([classId])
  @@index([studentId])
}

model Test {
  id              String   @id @default(cuid())
  type            TestType
  title           String
  description     String
  durationMinutes Int
  kkm             Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  questions Question[]
  attempts  StudentTestAttempt[]
}

model Question {
  id             String   @id @default(cuid())
  testId         String
  topic          String
  questionNumber Int?
  questionText   String
  optionA        String
  optionB        String
  optionC        String
  optionD        String
  optionE        String?
  correctAnswer  String
  explanation    String?
  questionImage  String?
  imageAlt       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  test    Test            @relation(fields: [testId], references: [id], onDelete: Cascade)
  answers StudentAnswer[]

  @@index([testId])
}

model StudentTestAttempt {
  id            String        @id @default(cuid())
  studentId     String
  testId        String
  attemptNumber Int
  score         Int?
  startedAt     DateTime      @default(now())
  submittedAt   DateTime?
  status        AttemptStatus @default(IN_PROGRESS)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  student Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  test    Test            @relation(fields: [testId], references: [id], onDelete: Cascade)
  answers StudentAnswer[]

  @@index([studentId, testId])
  @@index([submittedAt])
}

model StudentAnswer {
  id             String  @id @default(cuid())
  attemptId      String
  questionId     String
  studentId      String
  selectedAnswer String
  isCorrect      Boolean

  attempt  StudentTestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question           @relation(fields: [questionId], references: [id], onDelete: Cascade)
  student  Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([studentId])
  @@index([questionId])
}

model Module {
  id                   String   @id @default(cuid())
  title                String
  topic                String
  description          String
  content              String
  learningObjectives   String[] @default([])
  sections             Json?
  estimatedMinutes     Int      @default(12)
  minimumReadSeconds   Int      @default(45)
  requiredSectionCount Int      @default(3)
  isPrerequisite       Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  studentProgress StudentModuleProgress[]
}

model StudentModuleProgress {
  id               String               @id @default(cuid())
  studentId        String
  moduleId         String
  status           ModuleProgressStatus @default(NOT_STARTED)
  openedAt         DateTime?
  lastReadAt       DateTime?
  readSectionCount Int                  @default(0)
  readProgress     Int                  @default(0)
  reflectionText   String?
  completedAt      DateTime?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  module  Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([studentId, moduleId])
}

model LKM {
  id          String   @id @default(cuid())
  number      Int      @unique
  title       String
  description String
  instruction String
  topic       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions      StudentLKMSubmission[]
  peerAssessments  PeerAssessment[]
  learningFeedback LearningFeedback[]
  teacherLkmFeedback TeacherLkmFeedback[]
}

model StudentLKMSubmission {
  id              String              @id @default(cuid())
  studentId       String
  lkmId           String
  answerText      String
  uploadedFileUrl String?
  score           Int?
  status          LKMSubmissionStatus @default(SUBMITTED)
  submittedAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lkm     LKM     @relation(fields: [lkmId], references: [id], onDelete: Cascade)

  @@unique([studentId, lkmId])
  @@index([submittedAt])
}

model PeerAssessment {
  id                  String   @id @default(cuid())
  studentId           String
  lkmId               String
  assessedFriendName  String
  contributionScore   Int
  communicationScore  Int
  responsibilityScore Int
  collaborationScore  Int
  createdAt           DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lkm     LKM     @relation(fields: [lkmId], references: [id], onDelete: Cascade)
}

model LearningFeedback {
  id             String   @id @default(cuid())
  studentId      String
  lkmId          String
  reflectionText String
  rating         Int      @default(4)
  createdAt      DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lkm     LKM     @relation(fields: [lkmId], references: [id], onDelete: Cascade)

  @@unique([studentId, lkmId])
  @@index([studentId])
  @@index([lkmId])
}

model TeacherMessage {
  id          String    @id @default(cuid())
  teacherId   String
  studentId   String
  title       String
  content     String
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([studentId, readAt])
}

model AutomaticFeedback {
  id             String                      @id @default(cuid())
  studentId      String
  sourceType     AutomaticFeedbackSourceType
  sourceId       String
  score          Int
  strongTopics   String[]
  weakTopics     String[]
  recommendation String
  nextAction     String
  createdAt      DateTime                    @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model ActivityLog {
  id           String   @id @default(cuid())
  studentId    String
  activityType String
  description  String
  createdAt    DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([createdAt])
}

model TeacherNote {
  id        String   @id @default(cuid())
  teacherId String
  studentId String
  noteText  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([studentId])
}

model TeacherLkmFeedback {
  id           String   @id @default(cuid())
  teacherId    String
  studentId    String
  lkmId        String
  feedbackText String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lkm     LKM     @relation(fields: [lkmId], references: [id], onDelete: Cascade)

  @@unique([studentId, teacherId, lkmId])
  @@index([teacherId])
  @@index([studentId])
  @@index([lkmId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("WARNING")
  context   String   @default("")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}
